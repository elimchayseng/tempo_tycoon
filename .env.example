# ── Blockchain Configuration ──────────────────────────────────────────
RPC_URL=https://rpc.moderato.tempo.xyz
EXPLORER_URL=https://explore.moderato.tempo.xyz
CHAIN_ID=42431

# ── Server Configuration ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ── Simulation Parameters ────────────────────────────────────────────
ZOO_SIMULATION_ENABLED=true
AGENT_POLLING_INTERVAL=10000
NEED_DECAY_RATE=2
PURCHASE_THRESHOLD=30
MIN_BALANCE_THRESHOLD=10.0

# ── Authentication ────────────────────────────────────────────────────
ADMIN_TOKEN=
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000

# ── LLM (Optional — disabled by default) ─────────────────────────────
LLM_ENABLED=false
INFERENCE_URL=
INFERENCE_KEY=
LLM_MODEL=
LLM_MAX_CALLS_PER_SIMULATION=50
